# EcoSync Backend Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Origins - Comma-separated list of allowed frontend URLs
# For Vercel deployment, add your Vercel app URL(s) here
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
ALLOWED_ORIGINS=*